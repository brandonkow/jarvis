PORT=3000
# Number of trusted reverse-proxy hops in front of the app (Render = 1).
# Used to derive the real client IP from X-Forwarded-For for rate limiting.
ESTATELAB_TRUSTED_PROXY_HOPS=1
ESTATELAB_OWNER_TOKEN=change-this-before-using-owner-apis
ESTATELAB_DATA_DIR=./data
ESTATELAB_RAG_PATH=./rag/corpus.json
ESTATELAB_OBJECT_DIR=./data/objects
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
OPENROUTER_SITE_URL=
OPENAI_SERVICES_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=marin
OPENAI_TIMEOUT_MS=25000
ESTATELAB_AUTH_SESSION_DAYS=30
ESTATELAB_REQUIRE_EMAIL_VERIFICATION=false
ESTATELAB_EMAIL_WEBHOOK_URL=
ESTATELAB_EMAIL_WEBHOOK_SECRET=
ESTATELAB_AUTH_DEBUG_TOKENS=false
APEX_BILLING_ENFORCEMENT=false
APEX_BILLING_WEBHOOK_SECRET=
APEX_PRO_CHECKOUT_URL=
APEX_ADVISOR_CHECKOUT_URL=
APEX_PRO_PRICE_RM=59
APEX_ADVISOR_PRICE_RM=199
DATABASE_URL=
ESTATELAB_PG_POOL_MAX=5
